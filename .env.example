# Database
DATABASE_URL=postgresql://user:password@localhost:5432/wa-dashboard
DIRECT_URL=postgresql://user:password@localhost:5432/wa-dashboard
# Database khusus test — WAJIB berbeda dari DATABASE_URL. `bun test` menukar
# DATABASE_URL ke nilai ini (lihat tests/setup.ts) agar test tak mencemari DB dev.
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/wa-dashboard-test

# Dev Inspector
REACT_EDITOR=zed
PORT=3111
# Optional — Vite HMR WebSocket port (default 24678). Set jika bentrok dengan app lain.
HMR_PORT=24678

# Redis
REDIS_URL=redis://localhost:6379

# Claude Code Telegram Notification
TELEGRAM_NOTIFY_TOKEN=
TELEGRAM_NOTIFY_CHAT_ID=

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3111

# Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

SUPER_ADMIN_EMAIL=admin@example.com

MCP_SECRET=

# WhatsApp API (wwebjs-api container)
WA_API_BASE_URL=https://wa-api.wibudev.com
WA_API_KEY=

# WhatsApp Inbound Verification (WAV)
# Nomor server tujuan user mengirim token verifikasi (untuk field sendTo/instruksi).
# Kosongkan jika consumer app menampilkan nomor sendiri.
WA_VERIFY_SERVER_NUMBER=

# STG Debug & Deploy (debug-stg + deploy-stg MCP servers)
STG_BASE_URL=
STG_MCP_SECRET=
STG_STACK_NAME=

# GitHub (deploy-stg MCP server)
# PAT dengan scope: repo + workflow
GH_TOKEN=
