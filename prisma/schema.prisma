generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  QC
  ADMIN
  SUPER_ADMIN
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  READY_FOR_QC
  REOPENED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum VerifyStatus {
  PENDING
  VERIFIED
  EXPIRED
}

enum VerifyDelivery {
  PENDING
  DELIVERED
  FAILED
  DISABLED
}

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  password      String?
  role          Role     @default(USER)
  blocked       Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions      Session[]
  accounts      Account[]
  auditLogs     AuditLog[]
  reported      Ticket[]        @relation("TicketReporter")
  assigned      Ticket[]        @relation("TicketAssignee")
  comments      TicketComment[]

  @@map("user")
}

model Session {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("session")
}

model Account {
  id                    String    @id @default(uuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  detail    String?
  ip        String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_log")
}

model Ticket {
  id          String         @id @default(uuid())
  title       String
  description String
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  route       String?
  reporterId  String
  assigneeId  String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  closedAt    DateTime?
  deletedAt   DateTime?

  reporter User             @relation("TicketReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  assignee User?            @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  comments TicketComment[]
  evidence TicketEvidence[]

  @@index([status])
  @@index([reporterId])
  @@index([assigneeId])
  @@index([createdAt])
  @@map("ticket")
}

model TicketComment {
  id        String   @id @default(uuid())
  ticketId  String
  authorId  String?
  authorTag String
  body      String
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User?  @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@map("ticket_comment")
}

model TicketEvidence {
  id        String   @id @default(uuid())
  ticketId  String
  kind      String
  url       String
  note      String?
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("ticket_evidence")
}

// Singleton global config (id selalu "global") yang menegakkan aturan anti-ban
// pada pengiriman pesan WhatsApp lewat wwebjs-api (klien tidak resmi, rawan ban).
model WaPolicy {
  id                          String   @id @default("global")
  allowFirstContact           Boolean  @default(false)
  maxPerMinute                Int      @default(3)
  maxPerHour                  Int      @default(20)
  maxPerDay                   Int      @default(100)
  minIntervalSeconds          Int      @default(8)
  perRecipientCooldownSeconds Int      @default(60)
  requireAck                  Boolean  @default(true)
  contractVersion             Int      @default(1)
  // Balasan otomatis WhatsApp saat verifikasi WAV berhasil. Default MATI agar nomor
  // server tetap receive-only (unbannable) sampai sengaja dinyalakan. Pesan null =
  // pakai teks default di kode (bisa dikembalikan dari UI).
  verifyReplyEnabled          Boolean  @default(false)
  verifyReplyMessage          String?
  updatedAt                   DateTime @updatedAt
  updatedById                 String?

  @@map("wa_policy")
}

// App-consumer terdaftar untuk WhatsApp Inbound Verify (WAV). Tiap consumer =
// satu app eksternal; isolasi antar app ditegakkan lewat apiKeyHash (consumerId
// selalu diturunkan dari API key, tidak pernah dari input).
model VerifyConsumer {
  id            String   @id @default(uuid())
  name          String
  apiKeyHash    String   @unique
  apiKeyPrefix  String
  webhookUrl    String?
  webhookSecret String
  active        Boolean  @default(true)
  createdById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  requests VerifyRequest[]

  @@map("verify_consumer")
}

// Satu permintaan verifikasi nomor. id dipakai sebagai polling id (sumber
// kebenaran). Token one-time dicocokkan dengan pesan WA masuk oleh listener.
model VerifyRequest {
  id               String         @id @default(uuid())
  consumerId       String
  token            String         @unique
  expectedPhone    String?
  status           VerifyStatus   @default(PENDING)
  matchedPhone     String?
  matchedMessageId String?
  expiresAt        DateTime
  verifiedAt       DateTime?
  deliveryStatus   VerifyDelivery @default(PENDING)
  deliveryAttempts Int            @default(0)
  lastDeliveryAt   DateTime?
  lastDeliveryError String?
  // Penanda idempotency balasan WA (claim-then-send): diisi saat balasan sukses berhasil
  // di-claim, mencegah poller yang re-run mengirim balasan dobel ke user.
  replySentAt      DateTime?
  createdAt        DateTime       @default(now())

  consumer VerifyConsumer @relation(fields: [consumerId], references: [id], onDelete: Cascade)

  @@index([consumerId])
  @@index([token])
  @@index([status, expiresAt])
  @@map("verify_request")
}

// Audit mentah tiap pesan WA masuk yang diperiksa listener (match/tidak).
// Nomor selalu disimpan termask. Dibersihkan sweep > 24 jam.
model VerifyInboundLog {
  id         String   @id @default(uuid())
  sessionId  String
  fromMasked String
  tokenFound String?
  matched    Boolean  @default(false)
  consumerId String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@map("verify_inbound_log")
}
