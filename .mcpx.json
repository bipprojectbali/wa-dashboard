{
  "mcpServers": {
    "debug-dev": {
      "command": "bun",
      "args": ["run", "scripts/mcp/server.ts"],
      "env": {
        "MCP_SECRET": "${MCP_SECRET}"
      }
    },
    "debug-stg": {
      "command": "bun",
      "args": ["run", "scripts/mcp/stg-server.ts"],
      "env": {
        "BASE_URL": "${STG_BASE_URL}",
        "MCP_SECRET": "${STG_MCP_SECRET}"
      }
    },
    "deploy-stg": {
      "command": "bun",
      "args": ["run", "scripts/mcp/deploy.ts"],
      "env": {
        "STACK_NAME": "${STG_STACK_NAME}",
        "BASE_URL": "${STG_BASE_URL}",
        "ENV": "stg",
        "GH_TOKEN": "${GH_TOKEN}",
        "GH_REPO": "${GH_REPO}"
      }
    }
  }
}
