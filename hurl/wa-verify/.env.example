# Variables untuk hurl WAV E2E — SALIN ke .env (ter-gitignore), JANGAN commit nilai asli.
#
# Pakai:
#   hurl --variables-file hurl/wa-verify/.env hurl/wa-verify/start.hurl
#   hurl --variables-file hurl/wa-verify/.env --variable request_id=<id> hurl/wa-verify/poll.hurl
#
# Format: key=value per baris (tanpa export, tanpa quotes). Komentar diawali '#'.

# Base URL server yang diuji. Lokal: http://localhost:3111 — STG: https://...
base_url=http://localhost:3111

# API key consumer WAV (prefix wav_sk_). Server hanya simpan hash — ambil saat
# create/regenerate di /wa?tab=verify. JANGAN commit nilai asli.
api_key=wav_sk_xxxxxxxxxxxxxxxxxxxxxxxx

# Nomor yang consumer harapkan (mode login). Kosongkan untuk mode discovery
# (nomor pengirim jadi nomor terverifikasi).
expected_phone=628123456789
